    "antd": "^6.5.0",
    "axios": "^1.18.0",
    "dayjs": "^1.11.21",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^1.20.0",
    "react": "^19.2.6",
    "react-countdown-circle-timer": "^3.2.1",
    "react-dom": "^19.2.6",
    "react-qr-code": "^2.2.0",
    "react-router-dom": "^7.18.0",
    "react-router-hash-link": "^2.4.3",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.14",
